DATABASE_URL=postgresql://app_reader:password@localhost:5432/lpe
# Loader-only admin connection. Prefer Supabase direct; session pooler is acceptable when direct IPv6 is unavailable locally.
SUPABASE_ADMIN_DATABASE_URL=
# Local-only fallback when DATABASE_URL is unset. Build with scripts/build_local_sqlite.py.
LOCAL_SQLITE_PATH=data/local/lpe-local.sqlite3
# Loader-only secret used to create/update the read-only role.
APP_READER_PASSWORD=
FRONTEND_ORIGIN=http://localhost:5174
MAX_POINTS=25000
CELL_PX=32

# Optional AI capability
# AI_PROVIDER can be "anthropic" or "openrouter".
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=London Property Explorer
PINECONE_API_KEY=
PINECONE_INDEX=lpe-knowledge-v1
PINECONE_NAMESPACE=official-evidence-v1
PINECONE_EMBED_MODEL=llama-text-embed-v2
PINECONE_RERANK_MODEL=bge-reranker-v2-m3
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=london-property-explorer
LANGSMITH_TRACING=false
ANTHROPIC_INPUT_COST_PER_MILLION=1.0
ANTHROPIC_OUTPUT_COST_PER_MILLION=5.0
AGENT_HARD_COST_LIMIT_USD=0.08
AGENT_TIMEOUT_SECONDS=25
